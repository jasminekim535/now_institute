<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>People — Now Institute</title>
  <link href="https://fonts.googleapis.com/css2?family=Sofia+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Sofia Sans', sans-serif;
      background: #fff;
      color: #111;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Layout ── */
    .page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 40px 32px 100px;
    }

    /* ── Nav ── */
    .site-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 24px;
      border-bottom: 1px solid #e0e0e0;
      margin-bottom: 56px;
    }
    .site-logo {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #111;
      text-decoration: none;
    }
    .nav-links {
      display: flex;
      gap: 32px;
      list-style: none;
    }
    .nav-links a {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #999;
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: #111; }
    .nav-links a.active { color: #111; font-weight: 700; }

    /* ── People sub-nav ── */
    .people-nav {
      display: flex;
      border: 0.75px solid #e5e5e5;
      width: fit-content;
      margin-bottom: 52px;
    }
    .people-pill {
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-weight: 600;
      padding: 10px 28px;
      cursor: pointer;
      border-right: 0.75px solid #e5e5e5;
      color: #999;
      transition: all 0.2s;
      text-decoration: none;
    }
    .people-pill:last-child { border-right: none; }
    .people-pill.active { background: #111; color: #fff; }
    .people-pill:hover:not(.active) { background: #f5f5f5; color: #111; }

    /* ── Person header ── */
    .person-header {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      margin-bottom: 72px;
      align-items: center;
    }
    .person-photo {
      width: 100%;
      aspect-ratio: 4 / 5;
      overflow: hidden;
      background: #f0ede8;
    }
    .person-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(10%);
      display: block;
    }
    .person-info {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .person-name {
      font-size: 52px;
      font-weight: 700;
      line-height: 1;
      letter-spacing: -0.02em;
      color: #111;
    }
    .name-rule {
      width: 56px;
      height: 3px;
      background: #111;
    }
    .person-roles {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .role-item { display: flex; flex-direction: column; gap: 2px; }
    .role-label {
      font-size: 12px;
      font-weight: 500;
      color: #999;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .role-org {
      font-size: 17px;
      font-weight: 500;
      color: #111;
    }

    /* ── Section divider ── */
    .section-divider {
      border: none;
      border-top: 1px solid #e5e5e5;
      margin: 60px 0;
    }

    /* ── Section heading ── */
    .section-heading {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #111;
      margin-bottom: 28px;
    }

    /* ── Profile text ── */
    .profile-body { display: flex; flex-direction: column; gap: 20px; }
    .profile-text {
      font-size: 16px;
      line-height: 1.8;
      color: #444;
      font-weight: 400;
    }
    .profile-text strong { font-weight: 700; color: #111; }

    /* ── Education ── */
    .edu-list { display: flex; flex-direction: column; gap: 10px; }
    .edu-card {
      display: flex;
      align-items: center;
      border: 0.75px solid #e5e5e5;
      padding: 18px 22px;
      position: relative;
    }
    .edu-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: #111;
    }
    .edu-degree { font-size: 17px; font-weight: 600; color: #111; }
    .edu-school { font-size: 13px; color: #888; margin-top: 3px; }

    /* ── Awards ── */
    .awards-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .award-card {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      border: 0.75px solid #e5e5e5;
      padding: 14px 16px;
    }
    .award-year {
      font-size: 13px;
      font-weight: 700;
      color: #111;
      min-width: 38px;
      padding-top: 1px;
      letter-spacing: 0.02em;
    }
    .award-title {
      font-size: 14px;
      color: #444;
      line-height: 1.45;
    }

    /* ── Associations ── */
    .assoc-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .assoc-card {
      display: flex;
      align-items: center;
      border: 0.75px solid #e5e5e5;
      padding: 16px 22px;
      position: relative;
    }
    .assoc-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: #111;
    }
    .assoc-card span { font-size: 14px; color: #444; line-height: 1.4; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .person-header { grid-template-columns: 1fr; gap: 36px; }
      .person-name { font-size: 40px; }
      .awards-grid, .assoc-grid { grid-template-columns: 1fr; }
      .nav-links { gap: 20px; }
      .nav-links a { font-size: 11px; }
    }

    @media (max-width: 480px) {
      .page { padding: 24px 20px 60px; }
      .site-nav { flex-direction: column; align-items: flex-start; gap: 16px; }
    }
  </style>
</head>
<body>

<div class="page">

  <nav class="site-nav">
    <a href="#" class="site-logo">Now Institute</a>
    <ul class="nav-links">
      <li><a href="#">About</a></li>
      <li><a href="#">Research</a></li>
      <li><a href="#" class="active">People</a></li>
      <li><a href="#">Projects</a></li>
      <li><a href="#">News</a></li>
    </ul>
  </nav>

  <div class="people-nav">
    <a href="#" class="people-pill active">Faculty</a>
    <a href="#" class="people-pill">Staff</a>
    <a href="#" class="people-pill">Alumni</a>
  </div>

  <div class="person-header">
    <div class="person-photo">
      <!-- Replace this src with a local image path like: src="images/thom-mayne.jpg" -->
      <img
        src="https://www.figma.com/api/mcp/asset/d05aaa26-63dd-4acc-83fd-136f029641a0"
        alt="Thom Mayne"
      />
    </div>
    <div class="person-info">
      <div class="person-name">Thom<br>Mayne</div>
      <div class="name-rule"></div>
      <div class="person-roles">
        <div class="role-item">
          <div class="role-label">Founding Executive Director</div>
          <div class="role-org">The Now Institute</div>
        </div>
        <div class="role-item">
          <div class="role-label">Founding Design Director</div>
          <div class="role-org">Morphosis Architects</div>
        </div>
        <div class="role-item">
          <div class="role-label">Distinguished Professor</div>
          <div class="role-org">UCLA Department of Architecture and Urban Design</div>
        </div>
        <div class="role-item">
          <div class="role-label">Member</div>
          <div class="role-org">President's Committee on the Arts and Humanities</div>
        </div>
      </div>
    </div>
  </div>

  <hr class="section-divider" />

  <div class="section-heading">Profile</div>
  <div class="profile-body">
    <p class="profile-text">
      <strong>Thom Mayne</strong> founded Morphosis as a collective architectural practice engaged in cross-disciplinary research and design. As Design Director and thought leader of Morphosis, Mayne provides overall vision and project leadership to the firm. With permanent offices in Los Angeles and New York City, the firm currently employs over 50 architects and designers.
    </p>
    <p class="profile-text">
      Mayne's distinguished honors include the Pritzker Prize (2005) and the AIA Gold Medal (2013). He was appointed to the President's Committee on the Arts and Humanities in 2009, and was honored with the American Institute of Architects Los Angeles Gold Medal in 2000. With Morphosis, Thom Mayne has been the recipient of 25 Progressive Architecture Awards, over 100 American Institute of Architecture Awards and numerous other design recognitions. Under Mayne's direction, the firm has been the subject of various group and solo exhibitions throughout the world, including a large solo exhibition at the Centre Pompidou in Paris in 2006, the Contemporary Art Center in Cincinnati, the Walker Arts Institute in Minneapolis, and a major retrospective at the Netherlands Architectural Institute in 1999. Morphosis buildings and projects have been published extensively; the firm has been the subject of 23 monographs.
    </p>
    <p class="profile-text">
      Throughout his career, Mayne has remained active in the academic world. In 1972, he helped to found the Southern California Institute of Architecture. Since then, he has held teaching positions at Columbia, Yale (the Eliel Saarinen Chair in 1991), the Harvard Graduate School of Design (Eliot Noyes Chair in 1998), the Berlage Institute in the Netherlands, the Bartlett School of Architecture in London, and many other institutions around the world. There has always been a symbiotic relationship between Mayne's teaching and practice, evidenced in his concurrent position as Executive Director of the Now Institute at UCLA — a research and design initiative focusing on applying strategic urban thinking to real world issues. He is a tenured Professor at UCLA Architecture and Urban Design since 1993.
    </p>
  </div>

  <hr class="section-divider" />

  <div class="section-heading">Education</div>
  <div class="edu-list">
    <div class="edu-card">
      <div>
        <div class="edu-degree">M.Arch. II</div>
        <div class="edu-school">Harvard — Graduate School of Design</div>
      </div>
    </div>
    <div class="edu-card">
      <div>
        <div class="edu-degree">B.Arch.</div>
        <div class="edu-school">University of Southern California</div>
      </div>
    </div>
  </div>

  <hr class="section-divider" />

  <div class="section-heading">Awards &amp; Distinctions</div>
  <div class="awards-grid">
    <div class="award-card"><div class="award-year">2011</div><div class="award-title">Richard J. Neutra Award for Professional Excellence, California State Polytechnic University, Pomona</div></div>
    <div class="award-card"><div class="award-year">2009</div><div class="award-title">Centennial Medal, American Academy in Rome</div></div>
    <div class="award-card"><div class="award-year">2008</div><div class="award-title">Edward MacDowell Medal</div></div>
    <div class="award-card"><div class="award-year">2008</div><div class="award-title">Member, American Academy of Arts and Sciences</div></div>
    <div class="award-card"><div class="award-year">2008</div><div class="award-title">California College of the Art, Honorary Doctorate of Fine Art</div></div>
    <div class="award-card"><div class="award-year">2008</div><div class="award-title">New Jersey Institute of Technology, Honorary Doctorate of Humane Letters</div></div>
    <div class="award-card"><div class="award-year">2007</div><div class="award-title">AIA Los Angeles Presidential Award</div></div>
    <div class="award-card"><div class="award-year">2007</div><div class="award-title">AIA California Council, The Maybeck Award</div></div>
    <div class="award-card"><div class="award-year">2006</div><div class="award-title">National Design Award, Cooper-Hewitt National Design Museum</div></div>
    <div class="award-card"><div class="award-year">2006</div><div class="award-title">Alumni Merit Award, University of Southern California</div></div>
    <div class="award-card"><div class="award-year">2005</div><div class="award-title">Pritzker Architecture Prize</div></div>
    <div class="award-card"><div class="award-year">2004</div><div class="award-title">Fellow, American Institute of Architects (FAIA)</div></div>
    <div class="award-card"><div class="award-year">2001</div><div class="award-title">Chrysler Design Award of Excellence</div></div>
    <div class="award-card"><div class="award-year">2000</div><div class="award-title">Gold Medal, Los Angeles American Institute of Architects</div></div>
    <div class="award-card"><div class="award-year">1995</div><div class="award-title">Alumni of the Year, USC</div></div>
    <div class="award-card"><div class="award-year">1992</div><div class="award-title">Brunner Prize/Award in Architecture, American Academy of Arts and Letters</div></div>
    <div class="award-card"><div class="award-year">1992</div><div class="award-title">Member Elect, American Academy of Design</div></div>
    <div class="award-card"><div class="award-year">1987</div><div class="award-title">Rome Prize Fellowship, American Academy in Rome, Italy</div></div>
  </div>

  <hr class="section-divider" />

  <div class="section-heading">Professional Associations</div>
  <div class="assoc-grid">
    <div class="assoc-card"><span>President's Committee on the Arts and Humanities / Member</span></div>
    <div class="assoc-card"><span>Architecture League of New York / Board</span></div>
    <div class="assoc-card"><span>American Academy of Arts and Letters / Member</span></div>
    <div class="assoc-card"><span>Institute of Urban Design / Board</span></div>
    <div class="assoc-card"><span>American Academy in Rome / Trustee</span></div>
    <div class="assoc-card"><span>American Academy of Arts and Sciences / Member</span></div>
    <div class="assoc-card"><span>A+D Architecture and Design Museum Los Angeles / Advisory Board</span></div>
    <div class="assoc-card"><span>National Academy of Design / Member</span></div>
    <div class="assoc-card"><span>American Institute of Architects (FAIA)</span></div>
    <div class="assoc-card"><span>Southern California Institute of Architecture / Board of Trustees</span></div>
    <div class="assoc-card"><span>Global Green USA / Board</span></div>
  </div>

</div>

</body>
</html>
